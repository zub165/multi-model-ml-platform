# API bind port (pick a free port on the VPS)
# GoDaddy VPS: prefer 8890+ to avoid clashes with 80/443/3306 and common 8000-range services.
API_PORT=8890

# SQLite DB path
# DB_PATH=/home/you/ml-platform/backend/data/ml_platform.db

# Directory for .pkl artifacts (must be writable)
# MODEL_DIR=/home/you/ml-platform/backend/models

# Comma-separated origins allowed by CORS (your React dev server or nginx URL)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://zub165.github.io
