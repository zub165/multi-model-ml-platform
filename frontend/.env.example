# Backend base URL (no trailing slash).
# GoDaddy VPS (FastAPI default in repo): bind API on 8890 — see README. Django example: 8891.
VITE_API_URL=http://127.0.0.1:8890

# Ollama / Llama (optional; also set in UI → Connections)
# VITE_OLLAMA_URL=http://127.0.0.1:11434

# Public VPS IP for connection presets (remote browser → GoDaddy ML API)
# VITE_PUBLIC_HOST=208.109.215.53

# Optional: avoid clashing with other local apps
# VITE_DEV_PORT=5174
# VITE_PREVIEW_PORT=4174
